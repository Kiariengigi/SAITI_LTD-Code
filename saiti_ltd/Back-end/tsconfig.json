{
"compilerOptions":{
    "module": "NodeNext", 
    "moduleResolution": "NodeNext", 
    "target": "ES2020",
    "sourceMap": true, 
    "outDir": "dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "ignoreDeprecations": "6.0",
    "paths": {
        "@config/*": ["config/*"],
        "@middlewares/*": ["middlewares/*"],
        "@controllers/*": ["controllers/*"],
        "@routes/*": ["routes/*"],
        "@utils/*": ["utils/*"]
    },
    "types": ["node"]
}, 
"include": ["src/"],
}